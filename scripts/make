#!/bin/bash

set -e
set -o pipefail
umask 0022

# Get the absolute path to the directory where this script lives (e.g., /.../repo/scripts)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# Move up one level to the repository root (e.g., /.../repo)
REPODIR="$(dirname "$SCRIPT_DIR")"
# Ensure we can find the targets directory relative to the repo root
TARGETS_DIR="${REPODIR}/targets"

GIT_URL="https://github.com/gfunkmonk"
GNU_REL=gnutella
MUSL_REL=birthday

LLVM_TARGETS="AArch64;ARM;LoongArch;Mips;PowerPC;RISCV;SystemZ;X86;Sparc;M68k"
LLVM_EXPERIMENTAL_TARGETS_TO_BUILD="M68k"

install_packages() {
	sudo apt-get update
	sudo apt-get install -y --no-install-recommends \
		build-essential \
		ca-certificates \
		ccache \
		cmake \
		git \
		libz-dev \
		lld \
		ninja-build \
		python3 \
		wget \
		xz-utils \
		libzstd-dev
}

create_wrapper() {
    local wrapper_name="$1"
    local target_bin="$2"
    local filter_flags="$3"
    local extra_args="$4"

    if [ "$filter_flags" = "false" ]; then
        cat > "/opt/clang-cross/bin/${wrapper_name}" <<EOF
#!/bin/sh
BINDIR=\$(dirname "\$0")
exec "\${BINDIR}/${target_bin}" ${extra_args} "\$@"
EOF
    else
        # POSIX-safe filter: rebuild positional parameters via a sentinel so
        # arguments containing spaces/tabs/globs survive intact. Avoid the
        # classic "ARGS=\$ARGS \$arg" + unquoted-\$ARGS pattern which silently
        # corrupts such arguments.
        #
        # The filter drops the concatenated forms (e.g. --target=foo,
        # --sysroot=/path) via the glob in ${filter_flags}. The split forms
        # -target foo / --target foo / --sysroot /path take two argv slots,
        # so when we see the flag name alone we also drop the next argument;
        # otherwise the operand leaks through to GCC as a stray source file.
        # POSIX-safe filter: rebuild positional parameters via a sentinel so
        # arguments containing spaces/tabs/globs survive intact. Avoid the
        # classic "ARGS=\$ARGS \$arg" + unquoted-\$ARGS pattern which silently
        # corrupts such arguments.
        cat > "/opt/clang-cross/bin/${wrapper_name}" <<EOF
#!/bin/sh
BINDIR=\$(dirname "\$0")
set -- "\$@" __CLANG_CROSS_WRAPPER_END__
drop_next=false
while :; do
    arg="\$1"; shift
    if [ "\$arg" = __CLANG_CROSS_WRAPPER_END__ ]; then
        break
    fi
    if [ "\$drop_next" = true ]; then
        drop_next=false
        continue
    fi
    case "\$arg" in
        -target|--target|--sysroot)
            drop_next=true
            continue
            ;;
        ${filter_flags}) continue ;;
    esac
    set -- "\$@" "\$arg"
done
exec "\${BINDIR}/${target_bin}" ${extra_args} "\$@"
EOF
    fi
    chmod +x "/opt/clang-cross/bin/${wrapper_name}"
}

build_llvm() {
	# Ensure submodules are actually there
	if [ ! -f "llvm/llvm/CMakeLists.txt" ]; then
	    echo "ERROR: LLVM source missing. Run: git submodule update --init --recursive" >&2
	    exit 1
	fi

          # SECURITY FIX: Validate sudo access before proceeding
          if ! sudo -n true 2>/dev/null; then
              echo "ERROR: sudo access required but not available" >&2
              exit 1
          fi

	sudo mkdir -p /opt
	sudo chmod 0777 /opt
	mkdir -p build-llvm
	pushd build-llvm
	cmake -G Ninja -S ../llvm/llvm \
		-DCMAKE_C_COMPILER_LAUNCHER=ccache \
		-DCMAKE_CXX_COMPILER_LAUNCHER=ccache \
		-DLLVM_ENABLE_PROJECTS="clang;lld" \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/opt/clang-cross \
		-DCLANG_DEFAULT_LINKER=lld \
		-DCLANG_DEFAULT_PIE_ON_LINUX=ON \
		-DCLANG_LINK_CLANG_DYLIB=ON \
		-DENABLE_LINKER_BUILD_ID=ON \
		-DLLVM_ENABLE_RTTI=ON \
		-DLLVM_ENABLE_ZLIB=ON \
		-DLLVM_LINK_LLVM_DYLIB=ON \
		-DLLVM_TARGETS_TO_BUILD="${LLVM_TARGETS}" \
		-DLLVM_EXPERIMENTAL_TARGETS_TO_BUILD="${LLVM_EXPERIMENTAL_TARGETS_TO_BUILD}" \
		-DLLVM_INSTALL_TOOLCHAIN_ONLY=ON \
		-DLLVM_ENABLE_TELEMETRY=OFF \
		-DLLVM_INCLUDE_TESTS=OFF \
		-DLLVM_ENABLE_PLUGINS=OFF \
		-DLLVM_ENABLE_OCAMLDOC=OFF \
		-DLLVM_ENABLE_BINDINGS=OFF \
		-DLLVM_ENABLE_LIBXML2=OFF \
		-DCLANG_ENABLE_CIR=OFF \
		-DLLVM_USE_SPLIT_DWARF=ON \
		-DLLVM_PARALLEL_LINK_JOBS=1 \
		-DLLVM_ENABLE_ASSERTIONS=OFF \
		-DLLVM_OPTIMIZED_TABLEGEN=ON \
		-DLLVM_ENABLE_RUNTIMES="compiler-rt;libcxx;libcxxabi;libunwind"
	ninja install/strip
	popd

	# Check if install succeeded before wiping
	if [ -d "/opt/clang-cross/bin" ]; then
		rm -rf build-llvm
	fi

	sudo mv /opt/clang-cross .
	sudo chown -R root:root clang-cross
	sudo tar -cJvf clang-cross.tar.xz clang-cross
}

build_target() {
	TARGET="${1}"
          # BUG FIX: Validate target parameter
          if [ -z "${TARGET}" ]; then
              echo "ERROR: Target parameter is required" >&2
              exit 1
          fi

	# Use the variable defined at the top of the script
	if [ -f "${TARGETS_DIR}/${TARGET}/config" ]; then
		# shellcheck disable=SC1090
		. "${TARGETS_DIR}/${TARGET}/config"
	else
		echo "ERROR: Configuration for ${TARGET} not found in ${TARGETS_DIR}" >&2
		exit 1
	fi

	# Cleanup trap: ensure directory is writable before rm -rf
	trap 'sudo chmod -R +w "${TARGET}" 2>/dev/null || true; sudo rm -rf "${TARGET}"' EXIT

	if [ ! -f "clang-cross.tar.xz" ]; then
              echo "ERROR: clang-cross.tar.xz not found. Run build_llvm first." >&2
              exit 1
          fi

	sudo tar -xf clang-cross.tar.xz -C /opt
	sudo chown -R "$(id -u):$(id -g)" /opt/clang-cross
	case ${TARGET} in
		*gnu*)
			URL="${GIT_URL}/gnu-cross/releases/download/${GNU_REL}/${TARGET}.tar.xz"
			;;
		*musl*)
			URL="${GIT_URL}/musl-cross/releases/download/${MUSL_REL}/${TARGET}.tar.xz"
			;;
	esac
	downloaded=false
	for n in $(seq 0 9); do
              echo "Download attempt $((n + 1))/10 for ${TARGET}..."
              mkdir -p "${TARGET}" || {
                  echo "ERROR: Failed to create directory ${TARGET}" >&2
                  exit 1
              }
              if wget --retry-connrefused --waitretry=5 --read-timeout=20 --timeout=15 --tries=5 --progress=bar:force -O - "${URL}" 2>/dev/null | tar xJ -C "${TARGET}" --strip-components=1 2>/dev/null; then
			downloaded=true
	                    echo "Successfully downloaded ${TARGET}"
			break
		fi
                    echo "Download attempt $((n + 1)) failed, cleaning up..."
		rm -rf "${TARGET}"
              if [ "$n" -lt 9 ]; then
                  echo "Waiting 5 seconds before retry..."
                  sleep 5
              fi
	done
	if [ "${downloaded}" = "false" ]; then
		echo "ERROR: Failed to download ${URL} after 10 attempts" >&2
		exit 1
	fi
	find "${TARGET}" ! -type l -exec chmod +w {} +
	cp -a "${TARGET}/include" /opt/clang-cross/
	cp -a "${TARGET}/lib/gcc" /opt/clang-cross/lib/
	cp -a "${TARGET}/${TARGET}" /opt/clang-cross/
	rm -rf "/opt/clang-cross/lib/gcc/${TARGET}"/*/{install-tools,plugin}
	rm -rf "/opt/clang-cross/${TARGET}"/{bin,debug-root,lib}

    # For targets with no LLVM backend, install GCC binaries instead of clang wrappers
    case ${TARGET} in
	      sh4-*|or1k-*|m68k-*|microblaze-*|microblazeel-*)
                        echo "==> Architecture ${TARGET} using robust GCC fallback..."

		    # Copy the whole toolchain tree so cc1/cc1plus stay relative
		    cp -a "${TARGET}/." /opt/clang-cross/

		    # Copy real GCC binaries to bin/ (the cp -a above already does this,
		    # but be explicit so the paths are definitely real files, not symlinks)
		    for n in gcc g++ cpp ar nm objcopy objdump ranlib strip; do
		        if [ -f "${TARGET}/bin/${TARGET}-${n}" ]; then
          		  cp -af "${TARGET}/bin/${TARGET}-${n}" "/opt/clang-cross/bin/${TARGET}-${n}"
       		        fi
 		    done

 		   # Clang-named wrappers that call GCC, stripping clang-specific flags
 		   for c in clang:gcc clang++:g++ cpp:cpp; do
 		       create_wrapper "${TARGET}-${c%%:*}" "${TARGET}-${c##*:}" \
 		           "--target=*|-target|--sysroot=*|-fcolor-diagnostics" "${CLANG_ARGS}"
		   done

		   # Mask host clang
    		   ln -sf "${TARGET}-clang"   "/opt/clang-cross/bin/clang"
	             ln -sf "${TARGET}-clang++" "/opt/clang-cross/bin/clang++"

		   # Aliases
		   ln -sf "${TARGET}-clang"   "/opt/clang-cross/bin/${TARGET}-cc"
    		   ln -sf "${TARGET}-clang++" "/opt/clang-cross/bin/${TARGET}-c++"
		   ;;
                *)
	             echo "==> Architecture ${TARGET} using standard LLVM/Clang..."
		   for c in clang:clang clang++:clang++; do
            	       create_wrapper "${TARGET}-${c%%:*}" "${c##*:}" "false" \
                               "--target=${TARGET} --sysroot=\${BINDIR}/../${TARGET}/sysroot ${CLANG_ARGS}"
                       done

                       ln -sf "${TARGET}-clang"   "/opt/clang-cross/bin/clang"
       		   ln -sf "${TARGET}-clang++" "/opt/clang-cross/bin/clang++"
	             ln -sf "${TARGET}-clang"   "/opt/clang-cross/bin/${TARGET}-cc"
	             ln -sf "${TARGET}-clang++" "/opt/clang-cross/bin/${TARGET}-c++"

	             # LLVM tool wrappers only make sense for Clang targets
                       for n in ar:ar c++filt:cxxfilt nm:nm objcopy:objcopy objdump:objdump \
                               ranlib:ranlib size:size strings:strings strip:strip; do
                           create_wrapper "${TARGET}-${n%%:*}" "llvm-${n##*:}" "false" ""
                       done
                       ;;
        esac

        # Final cleanup and packaging
        sudo find /opt/clang-cross ! -type l -exec chmod -w {} + || true
        echo "==> Cleaning up build directory ${TARGET}..."
        sudo chmod -R +w "${TARGET}" 2>/dev/null || true
        sudo rm -rf "${TARGET}"
        sudo mv /opt/clang-cross "${TARGET}"
        sudo chown -R root:root "${TARGET}"
        env XZ_OPT="-T0" sudo tar -cJvf "${TARGET}.tar.xz" "${TARGET}"
        sudo sha256sum "${TARGET}.tar.xz" | awk '{ print $1 }' > "${TARGET}.tar.xz.sha256"
}

usage() {
    cat <<USAGE
Usage: $0 <subcommand>

Subcommands:
    llvm              Build the base clang-cross toolchain (LLVM/clang/lld).
    list              Print available targets (one per line) and exit.
    -h, --help        Show this help and exit.
    <target>          Build the cross toolchain for <target>. If
                      clang-cross.tar.xz is not present it is built first.

Targets are directories under ${TARGETS_DIR}/. Run '$0 list' to see them.
USAGE
}

list_targets() {
    if [ ! -d "${TARGETS_DIR}" ]; then
        echo "ERROR: targets directory not found: ${TARGETS_DIR}" >&2
        exit 1
    fi
    # Only list entries that actually have a config file, to avoid surfacing
    # partially-added targets that the build would then fail on anyway.
    (cd "${TARGETS_DIR}" && for d in */; do
        d="${d%/}"
        [ -f "${d}/config" ] && printf '%s\n' "${d}"
    done) | sort
}

suggest_targets() {
    local requested="$1"
    echo "ERROR: unknown target '${requested}'" >&2
    # Best-effort fuzzy suggestion: prefix-match on the first 4 chars.
    local prefix="${requested:0:4}"
    local hits
    hits="$(list_targets | grep -iF -- "${prefix}" | head -n 8 || true)"
    if [ -n "${hits}" ]; then
        echo "Did you mean one of:" >&2
        printf '%s\n' "${hits}" | sed 's/^/  /' >&2
    else
        echo "Run '$0 list' to see available targets." >&2
    fi
}

main() {
    local target="$1"

    case "${target}" in
        ""|-h|--help|help)
            usage
            [ -z "${target}" ] && exit 1 || exit 0
            ;;
        list)
            list_targets
            exit 0
            ;;
    esac

    if [ "${target}" != "llvm" ] && [ ! -f "${TARGETS_DIR}/${target}/config" ]; then
        suggest_targets "${target}"
        exit 1
    fi

    install_packages

    if [ ! -e clang-cross.tar.xz ]; then
        build_llvm
    fi

    if [ "${target}" != "llvm" ]; then
        build_target "${target}"
    fi
}

# Execute main function with all arguments
main "$@"

