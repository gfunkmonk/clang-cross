#!/bin/bash

set -e
set -o pipefail
umask 0022

# Get the absolute path to the directory where this script lives (e.g., /.../repo/scripts)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# Move up one level to the repository root (e.g., /.../repo)
REPODIR="$(dirname "$SCRIPT_DIR")"
# Ensure we can find the targets directory relative to the repo root
TARGETS_DIR="${REPODIR}/targets"

CT_URL="https://github.com/gfunkmonk"
CT_VER=twolittleendian
GF_URL="https://github.com/gfunkmonk"
GF_VER=farmer

LLVM_TARGETS="AArch64;ARM;LoongArch;Mips;PowerPC;RISCV;SystemZ;X86;Lanai;Sparc;M68k;OR1K;SuperH"
LLVM_EXPERIMENTAL_TARGETS_TO_BUILD="M68k"

install_packages() {
	sudo apt-get update
	sudo apt-get install -y --no-install-recommends \
		build-essential \
		ca-certificates \
		ccache \
		cmake \
		git \
		libz-dev \
		lld \
		ninja-build \
		python3 \
		wget \
		xz-utils
}

build_llvm() {
	sudo mkdir -p /opt
	sudo chmod 0777 /opt
	# Patch OR1K CMakeLists.txt to add missing component group declaration
	# (required by LLVM-Build.cmake which queries cmake TARGET "OR1K")
	grep -q "add_llvm_component_group(OR1K)" llvm/llvm/lib/Target/OR1K/CMakeLists.txt || \
		sed -i '1s/^/add_llvm_component_group(OR1K)\n/' llvm/llvm/lib/Target/OR1K/CMakeLists.txt
	mkdir -p build-llvm
	pushd build-llvm
	cmake -G Ninja -S ../llvm/llvm \
		-DCMAKE_C_COMPILER_LAUNCHER=ccache \
		-DCMAKE_CXX_COMPILER_LAUNCHER=ccache \
		-DLLVM_ENABLE_PROJECTS="clang;lld" \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/opt/clang-cross \
		-DCLANG_DEFAULT_LINKER=lld \
		-DCLANG_DEFAULT_PIE_ON_LINUX=ON \
		-DCLANG_LINK_CLANG_DYLIB=ON \
		-DENABLE_LINKER_BUILD_ID=ON \
		-DLLVM_ENABLE_RTTI=ON \
		-DLLVM_ENABLE_ZLIB=ON \
		-DLLVM_LINK_LLVM_DYLIB=ON \
		-DLLVM_TARGETS_TO_BUILD="${LLVM_TARGETS}" \
		-DLLVM_EXPERIMENTAL_TARGETS_TO_BUILD="${LLVM_EXPERIMENTAL_TARGETS_TO_BUILD}" \
		-DLLVM_INSTALL_TOOLCHAIN_ONLY=ON \
		-DLLVM_ENABLE_TELEMETRY=OFF \
		-DLLVM_INCLUDE_TESTS=OFF \
		-DLLVM_ENABLE_PLUGINS=OFF \
		-DLLVM_ENABLE_OCAMLDOC=OFF \
		-DLLVM_ENABLE_BINDINGS=OFF \
		-DLLVM_ENABLE_LIBXML2=OFF \
		-DCLANG_ENABLE_CIR=OFF \
		-DBUILD_SHARED_LIBS=OFF \
		-DCLANG_LINK_CLANG_DYLIB=OFF \
		-DLLVM_BUILD_LLVM_DYLIB=OFF \
		-DLLVM_LINK_LLVM_DYLIB=OFF \
		-DLLVM_USE_SPLIT_DWARF=ON \
		-DLLVM_PARALLEL_LINK_JOBS=1 \
		-DLLVM_ENABLE_RUNTIMES="compiler-rt;libcxx;libcxxabi;libunwind" \
		-DLLVM_ENABLE_ASSERTIONS=OFF \
		-DLLVM_OPTIMIZED_TABLEGEN=ON \
		-DLIBCXX_HAS_MUSL_LIBC=ON \
	ninja install/strip
	popd

          # Check if install succeeded before wiping
          if [ -d "/opt/clang-cross/bin" ]; then
            rm -rf build-llvm
          fi

	sudo mv /opt/clang-cross .
	sudo chown -R root:root clang-cross
	sudo tar -cJvf clang-cross.tar.xz clang-cross
}

build_target() {
	TARGET=${1}
          # Use the variable defined at the top of the script
          if [ -f "${TARGETS_DIR}/${TARGET}/config" ]; then
            . "${TARGETS_DIR}/${TARGET}/config"
          else
            echo "ERROR: Configuration for ${TARGET} not found in ${TARGETS_DIR}" >&2
            exit 1
          fi

	sudo tar -xf clang-cross.tar.xz -C /opt
	sudo chown -R $(id -u):$(id -g) /opt/clang-cross
	case ${TARGET} in
		*gnu*)
			URL="${CT_URL}/gnu-cross/releases/download/${CT_VER}/${TARGET}.tar.xz"
			;;
		*musl*)
			URL="${GF_URL}/musl-cross/releases/download/${GF_VER}/${TARGET}.tar.xz"
			;;
	esac
	downloaded=false
	mkdir -p "${TARGET}"
	for n in {0..9}; do
		if wget -O - "${URL}" | tar xJ -C "${TARGET}" --strip-components=1; then
    			downloaded=true
    			break
		fi
		rm -rf "${TARGET}"
		sleep 5
	done
	if [ "${downloaded}" = "false" ]; then
		echo "ERROR: Failed to download ${URL} after 10 attempts" >&2
		exit 1
	fi
	find "${TARGET}" ! -type l -exec chmod +w {} +
	cp -a "${TARGET}/include" /opt/clang-cross/
	cp -a "${TARGET}/lib/gcc" /opt/clang-cross/lib/
	cp -a "${TARGET}/${TARGET}" /opt/clang-cross/
	rm -rf "/opt/clang-cross/lib/gcc/${TARGET}"/*/{install-tools,plugin}
	rm -rf "/opt/clang-cross/${TARGET}"/{bin,debug-root,lib}
	# 1. Create Clang/LLVM-based wrappers with robust quoting
    for n in clang:clang clang++:clang++ cpp:clang-cpp; do
        wrapper_name="${TARGET}-${n%%:*}"
        binary_name="${n##*:}"
        
        # We use a single-quoted heredoc 'EOF' to prevent variable expansion 
        # of $0 and $@ during creation, but we allow ${CLANG_ARGS} to expand now.
        cat > "/opt/clang-cross/bin/${wrapper_name}" <<EOF
#!/bin/sh
BINDIR=\$(dirname "\$0")
TARGET="${TARGET}"
exec "\${BINDIR}/${binary_name}" --target="\${TARGET}" --sysroot="\${BINDIR}/../\${TARGET}/sysroot" ${CLANG_ARGS} "\$@"
EOF
        chmod +x "/opt/clang-cross/bin/${wrapper_name}"
    done

    # 2. Setup standard aliases
    ln -sf "${TARGET}-clang" "/opt/clang-cross/bin/${TARGET}-cc"
    ln -sf "${TARGET}-clang++" "/opt/clang-cross/bin/${TARGET}-c++"

    # 3. Create LLVM tool wrappers (ar, nm, etc.)
    for n in ar:ar c++filt:cxxfilt nm:nm objcopy:objcopy objdump:objdump ranlib:ranlib size:size strings:strings strip:strip; do
        wrapper_name="${TARGET}-${n%%:*}"
        llvm_tool="llvm-${n##*:}"
        
        cat > "/opt/clang-cross/bin/${wrapper_name}" <<EOF
#!/bin/sh
BINDIR=\$(dirname "\$0")
exec "\${BINDIR}/${llvm_tool}" "\$@"
EOF
        chmod +x "/opt/clang-cross/bin/${wrapper_name}"
    done
	# For targets with no LLVM backend, install GCC binaries instead of clang wrappers
	#case ${TARGET} in
    	#	sh4-*|or1k-*)
        		# 1. Remove the clang wrappers because this Clang build doesn't support these CPUs
        	#	rm -f /opt/clang-cross/bin/${TARGET}-clang
        	#	rm -f /opt/clang-cross/bin/${TARGET}-clang++
        	#	rm -f /opt/clang-cross/bin/${TARGET}-cpp
	        	# 2. Copy the real GCC binaries from the extracted musl-cross tarball
        		# Assuming you used: tar xJ -C "${TARGET}" --strip-components=1
        	#	for n in gcc g++ cpp ar nm objcopy objdump ranlib strip; do
            		# The binaries are now directly in ${TARGET}/bin/ due to --strip-components=1
          #  		bin_source="${TARGET}/bin/${TARGET}-${n}"
          #  		if [ -f "$bin_source" ]; then
          #      			cp "$bin_source" /opt/clang-cross/bin/
          #      			chmod +x "/opt/clang-cross/bin/${TARGET}-${n}"
          #  		fi
        	#	done
		# 3. Aggressively ensure Clang is dead and GCC is the captain
	#	rm -f "/opt/clang-cross/bin/${TARGET}-cc"
	#	rm -f "/opt/clang-cross/bin/${TARGET}-c++"
	#	ln -sf "${TARGET}-gcc" "/opt/clang-cross/bin/${TARGET}-cc"
	#	ln -sf "${TARGET}-g++" "/opt/clang-cross/bin/${TARGET}-c++"
		# Also wrap clang/clang++ to invoke gcc/g++ so scripts that
		# hardcode 'clang'/'clang++' instead of 'cc'/'c++' still work
#		cat > "/opt/clang-cross/bin/${TARGET}-clang" <<EOF
##!/bin/sh
#BINDIR=\$(dirname "\$0")
#exec "\${BINDIR}/${TARGET}-gcc" "\$@"
#EOF
#		chmod +x "/opt/clang-cross/bin/${TARGET}-clang"
#		cat > "/opt/clang-cross/bin/${TARGET}-clang++" <<EOF
##!/bin/sh
#BINDIR=\$(dirname "\$0")
#exec "\${BINDIR}/${TARGET}-g++" "\$@"
#EOF
#		chmod +x "/opt/clang-cross/bin/${TARGET}-clang++"
#        		;;
#	esac

	sudo find /opt/clang-cross ! -type l -exec chmod -w {} + || true
	rm -rf "${TARGET}"
	sudo mv /opt/clang-cross "${TARGET}"
	sudo chown -R root:root "${TARGET}"
	sudo tar -cJvf "${TARGET}.tar.xz" "${TARGET}"
	sudo sha256sum "${TARGET}.tar.xz" | awk '{ print $1 }' > "${TARGET}.tar.xz.sha256"
}

install_packages

if [ ! -e clang-cross.tar.xz ]; then
	build_llvm
fi

if [ "${1}" != "llvm" ]; then
	build_target ${1}
fi

# vim: set ts=4 sw=4 noexpandtab:
